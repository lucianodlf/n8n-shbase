# =============================================================================
# n8n-shbase — Variables de entorno
# =============================================================================
# Copiar este archivo a .env y completar los valores antes de ejecutar init.sh
# NUNCA commitear el archivo .env al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTIDAD DEL PROYECTO
# Usado como prefijo en los nombres de los contenedores Docker.
# Debe ser único entre proyectos para evitar conflictos.
# Ejemplo: notesmd, gastos-personal, erp-interno
# -----------------------------------------------------------------------------
PROJECT_NAME=mi-proyecto

# -----------------------------------------------------------------------------
# n8n — Configuración de acceso
# -----------------------------------------------------------------------------

# Puerto en el host donde se expone n8n.
# Rango reservado para instancias locales: 5678–5699
# Asignar un puerto único por proyecto (ver README — Tabla de puertos).
N8N_PORT=5678

# Nombre del share zrok2 (usado con: zrok2 share public ... -n public:<nombre>)
# Crear con: zrok2 create name -n public <nombre>  (ver README — Túnel zrok2)
# ⚠️  El nombre determina la URL pública — debe coincidir con WEBHOOK_URL (ver más abajo).
# Dejar vacío si no se usa zrok2.
ZROK_NAME=

# Clave de encriptación para las credenciales almacenadas en la DB.
# ⚠️  CRÍTICO: generada automáticamente por init.sh con `openssl rand -hex 32`
# ⚠️  NUNCA cambiar esta clave una vez que la instancia tenga credenciales guardadas.
#     Si se pierde o cambia, todas las credenciales quedan ilegibles.
N8N_ENCRYPTION_KEY=

# URL base para webhooks. Debe apuntar a la URL pública/local donde n8n es accesible.
# En desarrollo local: dejar vacío — init.sh lo genera automáticamente como http://localhost:{N8N_PORT}/
# Con zrok2: https://<ZROK_NAME>.<zona>.zrok.io/  — el nombre debe coincidir con ZROK_NAME (ver arriba).
# En producción: https://n8n.mi-dominio.com/ (ver README — Producción)
WEBHOOK_URL=

# Host y protocolo (no modificar en desarrollo local)
N8N_HOST=localhost
N8N_PROTOCOL=http

# -----------------------------------------------------------------------------
# n8n — Autenticación básica
# Activa la protección por usuario/contraseña en la UI de n8n.
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# -----------------------------------------------------------------------------
# n8n — API Key (para integración con n8n-mcp / Claude Code)
# Generada manualmente desde la UI de n8n post-deploy:
#   Settings → API → Create API Key
# Completar luego de la primera instalación y reejecutar init.sh.
# -----------------------------------------------------------------------------
N8N_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SCHEMA=public

# -----------------------------------------------------------------------------
# n8n-mcp — Propagación al proyecto padre (uso como submodule)
# Path relativo al directorio del submodule donde escribir el .mcp.json del padre.
# Default: ../../.mcp.json  (estructura estándar: raiz/services/n8n/)
# Cambiar si el submodule está en otro nivel de anidamiento.
# Dejar vacío para usar el default.
# -----------------------------------------------------------------------------
PARENT_MCP_PATH=

# -----------------------------------------------------------------------------
# Zona horaria
# Ver lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# -----------------------------------------------------------------------------
GENERIC_TIMEZONE=America/Argentina/Buenos_Aires
