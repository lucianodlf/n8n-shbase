{
  "mcpServers": {
    "n8n-mcp": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm", "--init",
        "-e", "MCP_MODE=stdio",
        "-e", "LOG_LEVEL=error",
        "-e", "DISABLE_CONSOLE_OUTPUT=true",
        "-e", "N8N_API_URL=http://host.docker.internal:N8N_PORT_PLACEHOLDER",
        "-e", "N8N_API_KEY=N8N_API_KEY_PLACEHOLDER",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ]
    }
  }
}
